{
  "compilerOptions": {
    /* Language */
    "target": "ES2020",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2020"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    /* JSX (React 기준) */
    "jsx": "react-jsx",
    /* Strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    /* Interop */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    /* Build */
    "isolatedModules": true,
    "noEmit": true,
    /* Paths (선택) */
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "src",
    "vite.config.ts"
  ],
  "exclude": [
    "src/redesign/app",
    "node_modules",
    "dist"
  ]
}
