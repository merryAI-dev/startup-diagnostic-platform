rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/profiles/$(request.auth.uid));
    }

    function hasCompany(companyId) {
      return firestore.exists(/databases/(default)/documents/companies/$(companyId));
    }

    function isAdmin() {
      return isSignedIn()
        && hasProfile()
        && firestore.get(/databases/(default)/documents/profiles/$(request.auth.uid)).data.role == "admin"
        && firestore.get(/databases/(default)/documents/profiles/$(request.auth.uid)).data.active == true;
    }

    function isConsultant() {
      return isSignedIn()
        && hasProfile()
        && firestore.get(/databases/(default)/documents/profiles/$(request.auth.uid)).data.role == "consultant"
        && firestore.get(/databases/(default)/documents/profiles/$(request.auth.uid)).data.active == true;
    }

    function isStaff() {
      return isSignedIn()
        && hasProfile()
        && firestore.get(/databases/(default)/documents/profiles/$(request.auth.uid)).data.role == "staff"
        && firestore.get(/databases/(default)/documents/profiles/$(request.auth.uid)).data.active == true;
    }

    function isCompanyOwner(companyId) {
      return isSignedIn()
        && hasCompany(companyId)
        && firestore.get(/databases/(default)/documents/companies/$(companyId)).data.ownerUid == request.auth.uid;
    }

    function isCompanyMember(companyId) {
      return isSignedIn()
        && hasProfile()
        && (
          isCompanyOwner(companyId)
          || firestore.get(/databases/(default)/documents/profiles/$(request.auth.uid)).data.companyId == companyId
        );
    }

    // Legacy path compatibility (companyId/fileId/fileName)
    match /company-files/{companyId}/{fileId}/{fileName} {
      function isAllowedFile() {
        return request.resource.size <= 50 * 1024 * 1024
          && request.resource.name.matches(".*\\.(pdf|PDF|png|PNG|jpg|JPG|jpeg|JPEG|svg|SVG|ai|AI)$");
      }

      allow read: if isAdmin() || isCompanyMember(companyId);
      allow create, update: if isAllowedFile() && (isAdmin() || isCompanyMember(companyId));
      allow delete: if isAdmin() || isCompanyMember(companyId);
    }

    match /office-hour-applications/{category}/{userId}/{filePath=**} {
      function isAllowedOfficeHourFile() {
        return request.resource.size <= 10 * 1024 * 1024
          && request.resource.name.matches(
            ".*\\.(pdf|PDF|doc|DOC|docx|DOCX|ppt|PPT|pptx|PPTX|xls|XLS|xlsx|XLSX|jpg|JPG|jpeg|JPEG|png|PNG)$"
          );
      }

      allow read: if isAdmin() || isConsultant() || (isSignedIn() && request.auth.uid == userId);
      allow write: if isSignedIn() && request.auth.uid == userId && isAllowedOfficeHourFile();
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /reports/{applicationId}/{fileName} {
      function isAllowedReportImage() {
        return request.resource.size <= 10 * 1024 * 1024
          && request.resource.name.matches(
            ".*\\.(jpg|JPG|jpeg|JPEG|png|PNG|webp|WEBP|heic|HEIC|heif|HEIF)$"
          );
      }

      allow read: if isAdmin() || isConsultant() || isStaff();
      allow create, update: if isAllowedReportImage() && (isAdmin() || isConsultant() || isStaff());
      allow delete: if isAdmin() || isConsultant() || isStaff();
    }
  }
}
