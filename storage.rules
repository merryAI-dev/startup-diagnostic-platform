rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == "admin"
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.active == true;
    }

    function isConsultant() {
      return isSignedIn()
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == "consultant"
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.active == true;
    }

    function isCompanyOwner(companyId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/companies/$(companyId)).data.ownerUid == request.auth.uid;
    }

    match /company-files/{companyId}/{fileId}/{fileName} {
      function isAllowedFile() {
        return request.resource.size <= 50 * 1024 * 1024
          && request.resource.name.matches(".*\\.(pdf|PDF|png|PNG|ai|AI)$");
      }

      allow read: if isAdmin() || isCompanyOwner(companyId);
      allow write: if isCompanyOwner(companyId) && isAllowedFile();
    }

    match /office-hour-applications/{category}/{userId}/{filePath=**} {
      function isAllowedOfficeHourFile() {
        return request.resource.size <= 10 * 1024 * 1024
          && request.resource.name.matches(
            ".*\\.(pdf|PDF|doc|DOC|docx|DOCX|ppt|PPT|pptx|PPTX|xls|XLS|xlsx|XLSX|jpg|JPG|jpeg|JPEG|png|PNG)$"
          );
      }

      allow read: if isAdmin() || isConsultant() || (isSignedIn() && request.auth.uid == userId);
      allow write: if isSignedIn() && request.auth.uid == userId && isAllowedOfficeHourFile();
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }
  }
}
