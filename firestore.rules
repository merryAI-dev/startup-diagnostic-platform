rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/profiles/$(request.auth.uid));
    }

    function isActiveUser() {
      return hasProfile()
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.active is bool
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.active == true;
    }

    function isAdmin() {
      return isActiveUser()
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == "admin";
    }

    function isConsultant() {
      return isActiveUser()
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == "consultant";
    }

    function isCompanyOwner(companyId) {
      return isActiveUser()
        && get(/databases/$(database)/documents/companies/$(companyId)).data.ownerUid == request.auth.uid;
    }

    match /profiles/{userId} {
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == "company"
        && (
          request.resource.data.requestedRole == null
          || request.resource.data.requestedRole in ["admin", "company", "consultant"]
        )
        && request.resource.data.active is bool
        && request.resource.data.active == false;

      allow read: if isSignedIn()
        && request.auth.uid == userId;
      allow read: if isAdmin();

      allow update: if isAdmin()
        && request.resource.data.role in ["admin", "company", "consultant"]
        && (
          request.resource.data.requestedRole == null
          || request.resource.data.requestedRole in ["admin", "company", "consultant"]
        )
        && request.resource.data.active is bool;

      allow delete: if false;
    }

    match /users/{userId} {
      allow read: if isSignedIn()
        && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn()
        && request.auth.uid == userId;
      allow update: if isSignedIn()
        && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /adminRoleRequests/{requestId} {
      allow read, write: if false;
    }

    match /companies/{companyId} {
      allow read: if isActiveUser()
        && (isCompanyOwner(companyId) || isAdmin());
      allow create: if isActiveUser()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isActiveUser()
        && isCompanyOwner(companyId)
        && request.resource.data.ownerUid == resource.data.ownerUid;
      allow delete: if false;
    }

    match /companies/{companyId}/companyInfo/{docId} {
      allow read: if isActiveUser()
        && (isCompanyOwner(companyId) || isAdmin());
      allow create, update: if isActiveUser()
        && isCompanyOwner(companyId);
      allow delete: if false;
    }

    match /companies/{companyId}/selfAssessment/{docId} {
      allow read: if isActiveUser()
        && (isCompanyOwner(companyId) || isAdmin());
      allow create, update: if isActiveUser()
        && isCompanyOwner(companyId);
      allow delete: if false;
    }

    match /companies/{companyId}/files/{fileId} {
      allow read: if isActiveUser()
        && (isCompanyOwner(companyId) || isAdmin());
      allow create: if isActiveUser()
        && isCompanyOwner(companyId)
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.storagePath is string
        && request.resource.data.name is string
        && request.resource.data.size is int;
      allow delete: if isActiveUser()
        && (isCompanyOwner(companyId) || isAdmin());
      allow update: if false;
    }

    match /consultants/{consultantId} {
      allow read: if isActiveUser();
      allow create: if isAdmin()
        || (
          isConsultant()
          && consultantId == request.auth.uid
          && request.resource.data.email is string
          && request.resource.data.email == request.auth.token.email
        );
      allow update: if isAdmin()
        || (
          isConsultant()
          && (
            consultantId == request.auth.uid
            || (
              resource.data.email is string
              && resource.data.email == request.auth.token.email
            )
            || (
              resource.data.secondaryEmail is string
              && resource.data.secondaryEmail == request.auth.token.email
            )
          )
          && request.resource.data.agendaIds == resource.data.agendaIds
        );
      allow delete: if isAdmin();
    }

    match /agendas/{agendaId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isAdmin();
    }

    match /programs/{programId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isAdmin();
    }

    match /officeHourSlots/{slotId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isAdmin() || isConsultant();
    }

    match /officeHourApplications/{applicationId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser()
        && request.resource.data.createdByUid == request.auth.uid;
      allow update: if isAdmin()
        || isConsultant()
        || (
          isActiveUser()
          && resource.data.createdByUid == request.auth.uid
          && request.resource.data.createdByUid == resource.data.createdByUid
          && request.resource.data.status == "cancelled"
        );
      allow delete: if false;
    }

    match /reports/{reportId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isAdmin() || isConsultant();
    }

    match /consents/{consentId} {
      allow read: if isActiveUser()
        && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isActiveUser()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.type in ["privacy", "marketing"]
        && request.resource.data.consented is bool
        && request.resource.data.version is string
        && request.resource.data.method is string;
      allow update, delete: if false;
    }
  }
}
