rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == "admin"
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.active == true;
    }

    match /profiles/{userId} {
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == "company"
        && (
          request.resource.data.requestedRole == null
          || request.resource.data.requestedRole in ["admin", "company"]
        )
        && request.resource.data.active is bool
        && request.resource.data.active == false;

      allow read: if isSignedIn()
        && (request.auth.uid == userId || isAdmin());

      allow update: if isSignedIn()
        && (
          (
            isAdmin()
            && request.resource.data.role in ["admin", "company"]
            && (
              request.resource.data.requestedRole == null
              || request.resource.data.requestedRole in ["admin", "company"]
            )
            && request.resource.data.active is bool
          )
          || (
            request.auth.uid == userId
            && request.auth.token.email_verified == true
            && request.resource.data.requestedRole != "admin"
            && request.resource.data.role == resource.data.role
            && request.resource.data.requestedRole == resource.data.requestedRole
            && request.resource.data.email == resource.data.email
            && request.resource.data.active is bool
            && resource.data.active == false
            && request.resource.data.active == true
          )
        );

      allow delete: if false;
    }

    match /adminRoleRequests/{requestId} {
      allow read, write: if false;
    }

    match /profiles/{userId}/companyInfo/{docId} {
      allow read: if isSignedIn()
        && (request.auth.uid == userId || isAdmin());
      allow create, update: if isSignedIn()
        && request.auth.uid == userId;
      allow delete: if false;
    }

    match /profiles/{userId}/selfAssessment/{docId} {
      allow read: if isSignedIn()
        && (request.auth.uid == userId || isAdmin());
      allow create, update: if isSignedIn()
        && request.auth.uid == userId;
      allow delete: if false;
    }
  }
}
